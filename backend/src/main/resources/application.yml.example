server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/flight_tracker?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
    username: root
    password: your_mysql_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  cache:
    type: caffeine
    caffeine:
      spec: maximumSize=200,expireAfterWrite=20m
opensky:
  client-id: your_client_id
  client-secret: your_client_secret
  auth-url: https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
  api-url: https://opensky-network.org/api
  filter-on-ground: true
  retry-max-attempts: 3
  retry-interval-seconds: 3
  token-refresh-advance-seconds: 300
  rate-limit-pause-seconds: 300
  polling-interval-seconds: 60
  bbox:
    lamin: 18.0
    lamax: 55.0
    lomin: 70.0
    lomax: 140.0
mock:
  china-flights:
    enabled: true
    count: 500

weather:
  api:
    key: YOUR_API_KEY
    base-url: http://api.openweathermap.org/data/2.5